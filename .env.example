# NeuroCarousel — переменные окружения
# Скопируй этот файл в .env и заполни значения

# Токен Telegram-бота (получить у @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Google Gemini API Key (бесплатно на aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face API Key (бесплатно на huggingface.co/settings/tokens)
HF_API_KEY=hf_your_token_here

# Опционально: модели Gemini через запятую (при 429 пробуются по очереди)
# GEMINI_MODELS=gemini-2.0-flash,gemini-2.0-flash-lite

# Upstash Redis — сессия между нажатиями на Vercel (бесплатно: console.upstash.com)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token

# Vercel (авто при VERCEL=1): 8 слайдов, 4 порции по 2, Pollinations
# SLIDES_COUNT=8
# BATCH_SIZE=2
# POLLINATIONS_ONLY=1
# FUNCTION_TIMEOUT_SEC=55
