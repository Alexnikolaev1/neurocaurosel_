# NeuroCarousel — переменные окружения
# Скопируй этот файл в .env и заполни значения

# Токен Telegram-бота (получить у @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Google Gemini API Key (бесплатно на aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face API Key (бесплатно на huggingface.co/settings/tokens)
HF_API_KEY=hf_your_token_here

# Опционально: модели Gemini через запятую (при 429 пробуются по очереди)
# GEMINI_MODELS=gemini-2.0-flash,gemini-2.0-flash-lite

# Upstash Redis — сессия между нажатиями на Vercel (бесплатно: console.upstash.com)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token

# Vercel (авто при VERCEL=1): 7 слайдов, по 1 картинке, картинки через HF Router
# SLIDES_COUNT=7
# BATCH_SIZE=1
# POLLINATIONS_ONLY=0
# Картинки (хотя бы один):
# POLLINATIONS_API_KEY=pk_...   ← с enter.pollinations.ai (рекомендуется на Vercel)
# HF_API_KEY=hf_...             ← Fine-grained + Inference Providers
# SKIP_GEMINI=0                 ← по умолчанию: сценарий через Gemini (при 429 — шаблон)
# SKIP_GEMINI=1                 ← только шаблон, без вызова Gemini
# FUNCTION_TIMEOUT_SEC=55
